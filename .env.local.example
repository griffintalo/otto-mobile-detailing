# Copy this file to .env.local for local development.
# On Vercel, add these under Project Settings -> Environment Variables.

# From your Supabase project: Settings -> API
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# The passcode you'll use to open the owner dashboard
OWNER_PASSCODE=pick-something-strong

# Any long random string (used to sign your login session)
SESSION_SECRET=paste-a-long-random-string-here
